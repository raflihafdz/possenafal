# Environment variables declared in this file are loaded by Next.js before running the build
# DO NOT COMMIT REAL SECRETS - use .env.local for local development with real credentials
# For production (Vercel), set these in Vercel Environment Variables dashboard

# Database - Use for local development (with Prisma Postgres or local PostgreSQL)
# For production, set DATABASE_URL in Vercel dashboard with your Neon database URL
# During build on Vercel, this will be overridden by the Vercel environment variable
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/possenafal?sslmode=disable"

# NextAuth Configuration
# IMPORTANT: Change AUTH_SECRET in production!
AUTH_SECRET="possenafal-secret-key-for-nextauth-jwt-sessions-change-in-production"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Public variables (safe to expose to browser)
NEXT_PUBLIC_APP_NAME="PossENafal POS"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_STORE_NAME="PossENafal Store"
NEXT_PUBLIC_STORE_ADDRESS="Jl. Contoh No. 123, Jakarta"
NEXT_PUBLIC_STORE_PHONE="+62 812 3456 7890"
